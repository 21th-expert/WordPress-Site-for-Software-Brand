{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "custom": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#0f172a",
          "name": "Midnight"
        },
        {
          "slug": "secondary",
          "color": "#2563eb",
          "name": "Blue"
        },
        {
          "slug": "accent",
          "color": "#38bdf8",
          "name": "Aqua"
        },
        {
          "slug": "background",
          "color": "#f8fafc",
          "name": "Background"
        },
        {
          "slug": "surface",
          "color": "#ffffff",
          "name": "Surface"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, sans-serif",
          "name": "Inter"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "14px",
          "name": "Small"
        },
        {
          "slug": "normal",
          "size": "18px",
          "name": "Normal"
        },
        {
          "slug": "large",
          "size": "32px",
          "name": "Large"
        },
        {
          "slug": "hero",
          "size": "48px",
          "name": "Hero"
        }
      ]
    },
    "layout": {
      "contentSize": "1080px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "color": {
      "background": "#f8fafc",
      "text": "#111827"
    },
    "typography": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "fontSize": "18px",
      "lineHeight": 1.75
    },
    "elements": {
      "h1": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": 1.1
        }
      },
      "h2": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": 1.2
        }
      },
      "h3": {
        "typography": {
          "fontWeight": "700"
        }
      }
    }
  }
}
